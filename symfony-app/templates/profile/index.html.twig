{% extends 'base.html.twig' %}

{% block title %}Profile - {{ user.username }}{% endblock %}

{% block styles %}
    <style>
        .profile-container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }
        
        .profile-header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 30px;
            border-bottom: 2px solid #f0f0f0;
        }
        
        .profile-avatar {
            width: 120px;
            height: 120px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 48px;
            font-weight: bold;
            margin: 0 auto 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }
        
        .profile-username {
            font-size: 2em;
            color: #333;
            margin-bottom: 5px;
        }
        
        .profile-handle {
            font-size: 1.2em;
            color: #999;
        }
        
        .profile-details {
            display: grid;
            gap: 25px;
        }
        
        .profile-field {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 12px;
            border-left: 4px solid #667eea;
        }
        
        .profile-field-label {
            font-size: 0.85em;
            color: #667eea;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .profile-field-value {
            font-size: 1.1em;
            color: #333;
            word-wrap: break-word;
        }
        
        .profile-field-empty {
            color: #999;
            font-style: italic;
        }
        
        .profile-bio {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 12px;
            border-left: 4px solid #764ba2;
            margin-top: 10px;
        }
        
        .profile-bio-label {
            font-size: 0.85em;
            color: #764ba2;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        
        .profile-bio-text {
            font-size: 1.1em;
            color: #555;
            line-height: 1.6;
        }
        
        .back-button {
            display: inline-block;
            margin-top: 30px;
            padding: 12px 30px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 600;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
        }
        
        .back-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }
        
        .profile-stats {
            display: flex;
            justify-content: center;
            gap: 40px;
            margin-top: 30px;
            padding-top: 30px;
            border-top: 2px solid #f0f0f0;
        }

        .profile-import {
            margin-top: 30px;
            padding-top: 30px;
            border-top: 2px solid #f0f0f0;
        }

        .profile-import-card {
            background: #f8f9fa;
            padding: 24px;
            border-radius: 12px;
            border-left: 4px solid #4caf50;
        }

        .profile-import-title {
            font-size: 1.1em;
            color: #333;
            margin-bottom: 8px;
        }

        .profile-import-subtitle {
            color: #666;
            margin-bottom: 18px;
            line-height: 1.5;
        }

        .profile-import-form {
            display: grid;
            gap: 12px;
            margin-bottom: 14px;
        }

        .profile-import-label {
            font-size: 0.9em;
            color: #333;
            font-weight: 600;
        }

        .profile-import-input {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #d0d7de;
            border-radius: 10px;
            font-size: 1em;
        }

        .profile-import-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .profile-import-button {
            padding: 12px 20px;
            border: 0;
            border-radius: 999px;
            color: white;
            font-weight: 600;
            cursor: pointer;
        }

        .profile-import-button.save {
            background: linear-gradient(135deg, #4caf50 0%, #2e7d32 100%);
        }

        .profile-import-button.import {
            background: linear-gradient(135deg, #ff9800 0%, #ef6c00 100%);
        }
        
        .stat-item {
            text-align: center;
        }
        
        .stat-number {
            font-size: 2em;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 5px;
        }
        
        .stat-label {
            font-size: 0.9em;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="profile-container">
        <div class="profile-header">
            <div class="profile-avatar">
                {{ user.username|slice(0, 1)|upper }}
            </div>
            <h1 class="profile-username">
                {% if user.name %}
                    {{ user.name }} {{ user.lastName|default('') }}
                {% else %}
                    {{ user.username }}
                {% endif %}
            </h1>
            <div class="profile-handle">@{{ user.username }}</div>
        </div>
        
        <div class="profile-details">
            <div class="profile-field">
                <div class="profile-field-label">{{ 'profile.field.email'|trans }}</div>
                <div class="profile-field-value">{{ user.email }}</div>
            </div>
            
            {% if user.age %}
                <div class="profile-field">
                    <div class="profile-field-label">{{ 'profile.field.age'|trans }}</div>
                    <div class="profile-field-value">{{ 'profile.field.age_value'|trans({'%age%': user.age}) }}</div>
                </div>
            {% endif %}
            
            {% if user.name %}
                <div class="profile-field">
                    <div class="profile-field-label">{{ 'profile.field.full_name'|trans }}</div>
                    <div class="profile-field-value">
                        {{ user.name }}
                        {% if user.lastName %}
                            {{ user.lastName }}
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
        
        {% if user.bio %}
            <div class="profile-bio">
                <div class="profile-bio-label">{{ 'profile.field.about_me'|trans }}</div>
                <div class="profile-bio-text">{{ user.bio }}</div>
            </div>
        {% endif %}
        
        <div class="profile-stats">
            <div class="stat-item">
                <div class="stat-number">{{ user.photos|length }}</div>
                <div class="stat-label">{{ 'profile.stats.photos'|trans }}</div>
            </div>
        </div>

        <div class="profile-import">
            <div class="profile-import-card">
                <h2 class="profile-import-title">{{ 'profile.import.title'|trans }}</h2>
                <p class="profile-import-subtitle">{{ 'profile.import.subtitle'|trans }}</p>

                <form method="post" action="{{ path('profile_save_phoenix_token') }}" class="profile-import-form">
                    <input type="hidden" name="_token" value="{{ csrf_token('profile_save_phoenix_token') }}">
                    <label for="phoenix_api_token" class="profile-import-label">{{ 'profile.import.token_label'|trans }}</label>
                    <input
                        id="phoenix_api_token"
                        name="phoenix_api_token"
                        type="text"
                        value="{{ user.phoenixApiToken }}"
                        placeholder="{{ 'profile.import.token_placeholder'|trans }}"
                        class="profile-import-input"
                    >
                    <div class="profile-import-actions">
                        <button type="submit" class="profile-import-button save">{{ 'profile.import.save_action'|trans }}</button>
                    </div>
                </form>

                <form method="post" action="{{ path('profile_import_photos') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('profile_import_photos') }}">
                    <div class="profile-import-actions">
                        <button type="submit" class="profile-import-button import">{{ 'profile.import.import_action'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
        
        <div style="text-align: center;">
            <a href="{{ path('home') }}" class="back-button">← {{ 'profile.navigation.back_to_gallery'|trans }}</a>
        </div>
    </div>
{% endblock %}
